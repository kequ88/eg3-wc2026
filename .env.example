# .env.example
#
# This file is SAFE TO COMMIT — it's just a template showing
# what variables are needed. It contains no real values.
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. .env is gitignored — it NEVER gets committed to GitHub
#
# VITE PREFIX RULE:
#   All env vars exposed to the browser MUST start with VITE_
#   Vite will refuse to expose any variable without this prefix.
#   This prevents accidentally leaking server-only secrets.

# ── FIREBASE ──────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── GOOGLE ANALYTICS ──────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=G-5S676SZZLD
